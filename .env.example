FLASK_SECRET_KEY=troque-esta-chave
FLASK_DEBUG=0
PORT=5003

# Opcao 1: URL completa do banco PostgreSQL/Supabase
# Para ambiente local/Vercel, prefira a URL do session pooler.
DATABASE_URL=postgresql://postgres.seu-projeto:sua-senha@aws-0-us-east-1.pooler.supabase.com:5432/postgres

# Opcao 2: montar por partes
SUPABASE_DB_URL=
SUPABASE_HOST=aws-0-us-east-1.pooler.supabase.com
SUPABASE_PORT=5432
SUPABASE_DATABASE=postgres
SUPABASE_USER=postgres.seu-projeto
SUPABASE_PASSWORD=
